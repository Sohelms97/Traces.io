rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Allow read access to all users (public website needs to see images)
      allow read: if true;
      
      // Allow write access only to authenticated users
      // In production, you'd want to restrict this further (e.g. only admins)
      allow write: if request.auth != null;
    }
  }
}
